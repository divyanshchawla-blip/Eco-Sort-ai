# Copy this file to ".env" and fill in your real values.

# 1) Gemini API key — FREE, no credit card needed
#    Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-key-here

# 2) Email sending — used for silent signup notifications
#    The Gmail account emails will be SENT FROM (needs an App Password,
#    not your normal Gmail password): https://myaccount.google.com/apppasswords
EMAIL_USER=your-sending-gmail@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password

# 3) Where signup notifications are delivered TO
NOTIFY_EMAIL_TO=divyansh6239538841@gmail.com

# Optional — defaults to 3000 if not set
PORT=3000
