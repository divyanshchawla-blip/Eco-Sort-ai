# Copy this file to ".env" and fill in your real values.

# 1) Gemini API key — FREE, no credit card needed
#    Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-key-here

# 2) Email sending — via Resend (HTTP API, works on Render's free tier
#    unlike Gmail SMTP, which free hosting tiers block as an anti-spam measure)
#    Get a free key at https://resend.com (no card needed)
RESEND_API_KEY=re_your-key-here

# Optional — default sender shown to recipients. Resend's shared test
# domain works out of the box with no setup; verify your own domain
# on resend.com later for a more professional "from" address.
RESEND_FROM=EcoSort AI <onboarding@resend.dev>

# 3) Where signup notifications are delivered TO
NOTIFY_EMAIL_TO=divyansh6239538841@gmail.com

# Optional — defaults to 3000 if not set
PORT=3000
